# PostgreSQL bağlantısı — Vercel Postgres / Neon üzerinden 2 tıkla oluşturulabilir.
# DATABASE_URL: uygulamanın çalışma zamanında kullandığı bağlantı (pooled olabilir).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# DIRECT_URL: DATABASE_URL pooled (pgbouncer) ise, migrate/deploy için doğrudan bağlantı.
# Pooled değilse boş bırakılabilir.
DIRECT_URL=""

# NextAuth için rastgele üretilmiş gizli anahtar: `openssl rand -base64 33`
AUTH_SECRET=""

# Medya kütüphanesi için Vercel Blob — Vercel projesinde Storage > Blob'dan
# bir store oluşturunca token otomatik verilir.
BLOB_READ_WRITE_TOKEN=""

# Seed admin kullanıcısı — yalnızca `npx prisma db seed` ilk kez çalıştığında kullanılır.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Admin"
